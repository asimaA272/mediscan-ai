# Copy this file to .env and fill in your real keys
# NEVER commit the actual .env file to GitHub

# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Get free key: https://app.roboflow.com -> Settings -> API Key
ROBOFLOW_API_KEY=your-roboflow-key-here
# The model endpoint slug, e.g. "chest-xray-pneumonia/1" (see Roboflow Universe)
ROBOFLOW_MODEL_ID=your-model-id-here

# You already have this one - no signup needed for basic use
PUBMED_API_KEY=your-pubmed-key-here

# Optional: leave default for local dev
ALLOWED_ORIGIN=http://localhost:5173
